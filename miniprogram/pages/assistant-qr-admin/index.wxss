page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(20, 184, 166, 0.2), transparent 28%),
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.22), transparent 30%),
    linear-gradient(180deg, #f5f8fc 0%, #edf3fa 52%, #eef5f7 100%);
}

.page-shell {
  min-height: 100vh;
  color: #0f172a;
  font-family: "PingFang SC", sans-serif;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(247, 250, 252, 0.82);
  backdrop-filter: blur(20rpx);
}

.custom-nav-inner {
  height: 88rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.custom-nav-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.custom-nav-caption {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.nav-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.nav-triangle-left {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 20rpx solid #0f172a;
  margin-left: -4rpx;
}

.nav-home-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.nav-home-roof {
  position: absolute;
  top: -2rpx;
  left: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid #0f172a;
  border-left: 4rpx solid #0f172a;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.nav-home-body {
  position: absolute;
  left: 5rpx;
  bottom: 0;
  width: 18rpx;
  height: 16rpx;
  border: 4rpx solid #0f172a;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.page-body {
  position: relative;
  overflow: hidden;
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(24rpx);
  pointer-events: none;
}

.ambient-left {
  top: 28rpx;
  left: -90rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(16, 185, 129, 0.14);
}

.ambient-right {
  top: 120rpx;
  right: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(59, 130, 246, 0.16);
}

.ambient-bottom {
  bottom: 80rpx;
  left: 50%;
  margin-left: -160rpx;
  width: 320rpx;
  height: 180rpx;
  background: rgba(148, 163, 184, 0.1);
}

.hero-card,
.status-card,
.action-card,
.empty-state {
  width: 100%;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.06);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #475569;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 58rpx;
  line-height: 1.15;
  font-weight: 700;
}

.hero-subtitle,
.action-tip,
.status-path,
.empty-state {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #64748b;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.status-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.status-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef6ff 100%);
}

.status-label {
  font-size: 22rpx;
  color: #64748b;
}

.status-value {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  word-break: break-all;
}

.qr-preview-shell {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 16rpx 36rpx rgba(15, 23, 42, 0.08);
}

.qr-preview {
  width: 100%;
  height: 520rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.ghost-btn {
  margin-top: 18rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.ghost-btn::after {
  border: none;
}

.ghost-btn-full {
  width: 100%;
}

.warn-btn {
  border: 1rpx solid rgba(220, 38, 38, 0.16);
  background: linear-gradient(180deg, #fff5f5 0%, #fff1f2 100%);
  color: #b91c1c;
}

.primary-btn {
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  background: linear-gradient(135deg, #16a34a, #2563eb);
  color: #ffffff;
}

@media (max-width: 480px) {
  .status-meta {
    grid-template-columns: 1fr;
  }
}
