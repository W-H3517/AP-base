<view class="page-shell">
  <view class="custom-nav" style="padding-top: {{navMetrics.statusBarHeight}}px;">
    <view class="custom-nav-inner">
      <view class="custom-nav-main">
        <view class="custom-nav-caption">首页</view>
      </view>
      <view class="custom-nav-space" style="width: {{navMetrics.capsuleWidth}}px;"></view>
    </view>
  </view>

  <view class="page-body" style="padding-top: {{navMetrics.totalHeight + 20}}px;">
    <view class="hero-card">
      <view class="hero-top">
        <view class="hero-copy">
          <view class="hero-title">AP题库答题系统</view>
        </view>
      </view>

      <view class="action-stack">
        <view class="action-card action-card-primary" bindtap="openQuestionBrowser">
          <view class="action-card-title">在线答题</view>
          <view class="action-card-tip">逐题作答，交卷后立即进入回顾模式</view>
        </view>
        <view class="action-card action-card-secondary" bindtap="openPracticeHistory">
          <view class="action-card-title">做题记录</view>
          <view class="action-card-tip">查看历史提交时间、分数摘要和逐题详情</view>
        </view>
      </view>
    </view>

    <view class="refresh-card">
      <button class="ghost-btn ghost-btn-full" bindtap="getCurrentUser" loading="{{loadingUser}}">刷新</button>
    </view>

    <view class="admin-card" wx:if="{{isAdmin}}">
      <view class="section-title">管理入口</view>
      <view class="admin-actions">
        <view class="mini-action" bindtap="openQuestionAdmin">题目管理</view>
        <view class="mini-action mini-action-plain" bindtap="initCollections">初始化集合</view>
      </view>
    </view>
  </view>

  <cloud-tip-modal showTipProps="{{showTip}}" title="{{title}}" content="{{content}}" bindclose="hideCloudTip"></cloud-tip-modal>
</view>
