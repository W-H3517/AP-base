/**index.wxss**/

page {
  padding-top: 36rpx;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.14), transparent 26%),
    radial-gradient(circle at top left, rgba(22, 163, 74, 0.16), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f4f8f6 100%);
  padding-bottom: 60rpx;
}

.container {
  font-family: PingFang SC;
}

.title {
  font-family: PingFang SC;
  font-weight: 700;
  color: #0f172a;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}
.function_title {
  font-family: PingFang SC;
  font-weight: 500;
  color: #000000;
  font-size: 36rpx;
  text-align: left;
  width: 93%;
  margin-top: 50rpx;
}

.top_tip {
  font-size: 28rpx;
  font-family: PingFang SC;
  font-weight: 400;
  color: #64748b;
  margin-bottom: 28rpx;
}

.hero-card {
  width: 90%;
  margin: 0 auto 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.hero-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.hero-tip {
  margin-bottom: 0;
}

.hero-role {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #16a34a, #2563eb);
  color: #fff;
  font-size: 24rpx;
}

.hero-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-card {
  min-height: 160rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  box-sizing: border-box;
}

.action-card-primary {
  background: linear-gradient(135deg, #16a34a, #2563eb);
}

.action-card-primary .action-card-title,
.action-card-primary .action-card-tip {
  color: #ffffff;
}

.action-card-admin {
  background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
  border-color: rgba(249, 115, 22, 0.18);
}

.action-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.action-card-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.examples_container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  align-items: center;
}

.example_item {
  border: 3rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 24rpx;
  width: 90%;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.power {
  margin-top: 30rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.96);
  width: 90%;
  padding-bottom: 1rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.power_info {
  display: flex;
  padding: 30rpx 25rpx;
  align-items: center;
  justify-content: space-between;
}

.power_info_more {
  width: 30rpx;
  height: 30rpx;
  transform: rotate(90deg);
}

.power_info_less {
  width: 30rpx;
  height: 30rpx;
  transform: rotate(270deg);
}

.power_info_text {
  display: flex;
  flex-direction: column;
}

.power_info_text_title {
  margin-bottom: 10rpx;
  font-weight: 400;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  font-family: 'PingFang SC';
  color: #000;
}

.power_info_text_tag {
  margin-left: 20rpx;
  background-color: #fbe0e0;
  color: #e54545;
  padding: 0 7px;
  font-size: 14px;
  vertical-align: middle;
  border-radius: 3px;
}

.power_info_text_tip {
  color: rgba(0, 0, 0, 0.6);
  font-size: 28rpx;
  padding-right: 30rpx;
}

.power_item {
  padding: 30rpx 25rpx;
  display: flex;
  justify-content: space-between;
}

.power_item_title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.power_item_icon {
  width: 30rpx;
  height: 30rpx;
}

.line {
  width: 95%;
  margin: 0 auto;
  height: 2rpx;
  background-color: rgba(0, 0, 0, 0.1);
}

.environment {
  color: rgba(0, 0, 0, 0.4);
  font-size: 24rpx;
  margin-top: 25%;
}

.code_box {
  width: 90%;
  margin: 0 auto 24rpx;
  background-color: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.code_box-elevated {
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.code_box_title {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.85);
  margin-bottom: 16rpx;
}

.code_box_record {
  display: flex;
  align-items: center;
}

.code_box_record_title {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  padding: 16rpx 0;
}

.code_box_record_detail {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.85);
  padding: 16rpx 0;
  word-break: break-all;
}

.btn-full {
  width: 90%;
  margin: 0 auto 16rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  color: #fff;
  background: linear-gradient(135deg, #16a34a, #2563eb);
  border-radius: 18rpx;
}

.btn-secondary {
  background: #ffffff;
  color: #1e293b;
  border: 1rpx solid rgba(37, 99, 235, 0.18);
}

.button_clear {
  width: 90%;
  margin: 0 auto 16rpx;
  min-height: 80rpx;
  line-height: 40rpx;
  text-align: center;
  color: #1aad19;
  background-color: rgba(26, 173, 25, 0.08);
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

@media (max-width: 480px) {
  .hero-title-row {
    flex-direction: column;
  }

  .hero-actions {
    grid-template-columns: 1fr;
  }
}
