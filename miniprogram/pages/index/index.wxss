page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(22, 163, 74, 0.18), transparent 28%),
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.18), transparent 30%),
    linear-gradient(180deg, #f7fafc 0%, #eff4f9 100%);
}

.page-shell {
  min-height: 100vh;
  color: #0f172a;
  font-family: "PingFang SC", sans-serif;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(247, 250, 252, 0.82);
  backdrop-filter: blur(20rpx);
}

.custom-nav-inner {
  height: 88rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.custom-nav-main {
  display: flex;
  flex-direction: column;
}

.custom-nav-caption {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.custom-nav-space {
  flex-shrink: 0;
}

.page-body {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.hero-card,
.refresh-card,
.admin-card {
  width: 100%;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.hero-top {
  display: block;
}

.hero-copy {
  flex: 1;
}

.hero-title {
  font-size: 72rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -1.5rpx;
}

.action-stack {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-card {
  padding: 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.action-card-primary {
  background: linear-gradient(135deg, #1fa971 0%, #2f6ee5 100%);
  border-color: transparent;
  box-shadow: 0 20rpx 40rpx rgba(47, 110, 229, 0.22);
}

.action-card-primary .action-card-title,
.action-card-primary .action-card-tip {
  color: #ffffff;
}

.action-card-secondary {
  background: rgba(255, 255, 255, 0.86);
}

.action-card-title {
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
}

.action-card-tip {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #64748b;
}

.refresh-card,
.admin-card {
  margin-top: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0f172a;
}

.ghost-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
  background: #ffffff;
  color: #2563eb;
  font-size: 24rpx;
}

.ghost-btn::after {
  border: none;
}

.ghost-btn-full {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

.admin-actions {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.mini-action {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1fa971 0%, #2f6ee5 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.mini-action-plain {
  background: #f8fafc;
  color: #0f172a;
}

@media (max-width: 480px) {
  .admin-actions {
    grid-template-columns: 1fr;
  }
}
