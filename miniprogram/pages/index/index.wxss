page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(20, 184, 166, 0.2), transparent 28%),
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.22), transparent 30%),
    linear-gradient(180deg, #f5f8fc 0%, #edf3fa 52%, #eef5f7 100%);
}

.page-shell {
  min-height: 100vh;
  color: #0f172a;
  font-family: "PingFang SC", sans-serif;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(247, 250, 252, 0.82);
  backdrop-filter: blur(20rpx);
}

.custom-nav-inner {
  height: 88rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.custom-nav-main {
  display: flex;
  flex-direction: column;
}

.custom-nav-caption {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.custom-nav-space {
  flex-shrink: 0;
}

.page-body {
  position: relative;
  overflow: hidden;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(24rpx);
  pointer-events: none;
}

.ambient-left {
  top: 28rpx;
  left: -90rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(16, 185, 129, 0.14);
}

.ambient-right {
  top: 120rpx;
  right: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(59, 130, 246, 0.16);
}

.ambient-bottom {
  bottom: 80rpx;
  left: 50%;
  margin-left: -160rpx;
  width: 320rpx;
  height: 180rpx;
  background: rgba(148, 163, 184, 0.1);
}

.hero-card,
.refresh-card,
.admin-card,
.assistant-card,
.share-cta-card,
.question-card,
.loading-state,
.empty-state {
  width: 100%;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 32rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 251, 255, 0.94) 48%, rgba(243, 249, 255, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow:
    0 28rpx 72rpx rgba(15, 23, 42, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.hero-shine {
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 280rpx;
  height: 180rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0));
  transform: rotate(-14deg);
  pointer-events: none;
}

.hero-top {
  display: block;
  position: relative;
  z-index: 1;
}

.hero-copy {
  flex: 1;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #475569;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 72rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -1.5rpx;
}

.action-stack {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.action-card-primary {
  background: linear-gradient(135deg, #1fa971 0%, #2f6ee5 100%);
  border-color: transparent;
  box-shadow: 0 20rpx 40rpx rgba(47, 110, 229, 0.22);
}

.action-card-primary .action-card-title,
.action-card-primary .action-card-tip {
  color: #ffffff;
}

.action-card-secondary {
  background: rgba(255, 255, 255, 0.86);
}

.action-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-card-kicker {
  font-size: 22rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  opacity: 0.9;
}

.action-card-index {
  font-size: 24rpx;
  opacity: 0.7;
}

.action-card-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 700;
}

.action-card-tip {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #64748b;
}

.action-card-arrow {
  margin-top: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 124rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 24rpx;
  backdrop-filter: blur(12rpx);
}

.action-card-arrow-secondary {
  background: rgba(37, 99, 235, 0.08);
  color: #2563eb;
}

.refresh-card,
.admin-card,
.assistant-card,
.share-cta-card,
.question-card,
.loading-state,
.empty-state {
  margin-top: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0f172a;
}

.refresh-card-label {
  margin-bottom: 18rpx;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: #94a3b8;
}

.ghost-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  color: #2563eb;
  font-size: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
}

.ghost-btn::after {
  border: none;
}

.ghost-btn-full {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

.admin-actions {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.mini-action {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #159a6b 0%, #2f6ee5 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.mini-action-plain {
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  color: #0f172a;
}

.assistant-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #eff8ff 0%, #ffffff 42%, #ecfeff 100%);
  border: 1rpx solid rgba(125, 211, 252, 0.35);
  box-shadow: 0 24rpx 52rpx rgba(14, 116, 144, 0.12);
}

.assistant-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(14, 116, 144, 0.1);
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
}

.assistant-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.35;
}

.assistant-subtitle {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #64748b;
}

.assistant-qr-shell {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 16rpx 36rpx rgba(15, 23, 42, 0.08);
}

.assistant-qr {
  width: 100%;
  height: 560rpx;
  display: block;
  border-radius: 28rpx;
  background: #ffffff;
}

.assistant-placeholder {
  margin-top: 26rpx;
  padding: 72rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx dashed rgba(15, 118, 110, 0.28);
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
  font-size: 30rpx;
  line-height: 1.7;
  color: #64748b;
}

.assistant-actions-hint {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.7;
  color: #0f766e;
}

.share-cta-text,
.loading-state,
.empty-state {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #64748b;
}

.share-cta-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.question-card {
  position: relative;
  overflow: hidden;
}

.progress-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.progress-badge,
.question-tag,
.chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.progress-badge {
  background: #dbeafe;
  color: #1d4ed8;
}

.question-tag {
  background: #ecfccb;
  color: #3f6212;
}

.image-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.stem-image-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.stem-scroll-hint {
  font-size: 22rpx;
  color: #64748b;
}

.stem-zoom-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stem-zoom-btn,
.stem-zoom-reset {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 52rpx;
  height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.stem-zoom-reset {
  background: #dbeafe;
  color: #1d4ed8;
}

.stem-zoom-value {
  min-width: 88rpx;
  text-align: center;
  font-size: 22rpx;
  color: #334155;
}

.stem-image-scroll {
  width: 100%;
  white-space: nowrap;
  border-radius: 22rpx;
  background: #f8fafc;
  padding-bottom: 12rpx;
  box-sizing: border-box;
}

.stem-content-image {
  min-width: 100%;
  border-radius: 22rpx;
  background: #f8fafc;
}

.stem-card,
.option-card {
  border-radius: 22rpx;
  background: #f8fafc;
}

.stem-card {
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #0f172a;
}

.section-title {
  margin: 24rpx 0 16rpx;
}

.option-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  padding: 22rpx;
  border: 2rpx solid transparent;
}

.option-card-preview {
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
}

.option-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.option-key {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.option-state {
  font-size: 22rpx;
  color: #16a34a;
}

.option-state-preview {
  color: #64748b;
}

.option-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #334155;
}

.option-image,
.grouped-image {
  width: 100%;
  border-radius: 22rpx;
  overflow: hidden;
  background: #f8fafc;
}

.placeholder-image {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.6;
  border: 1rpx dashed rgba(148, 163, 184, 0.55);
  box-sizing: border-box;
}

.option-image-placeholder,
.grouped-image-placeholder {
  min-height: 220rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.chip {
  background: #e2e8f0;
  color: #334155;
}

@media (max-width: 480px) {
  .admin-actions {
    grid-template-columns: 1fr;
  }
}
