page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(34, 197, 94, 0.14), transparent 34%),
    linear-gradient(180deg, #f8fbff 0%, #f4fbf7 100%);
  padding: 28rpx 0 40rpx;
}

.page-container {
  width: 100%;
}

.hero-card,
.summary-card,
.question-card,
.loading-state,
.empty-state {
  width: 90%;
  margin: 0 auto 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  box-shadow: 0 24rpx 60rpx rgba(24, 39, 75, 0.08);
  box-sizing: border-box;
  padding: 28rpx;
}

.hero-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #516074;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-stat {
  padding: 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef6ff 100%);
}

.hero-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.hero-stat-label,
.summary-label,
.option-state {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.08);
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-value {
  max-width: 70%;
  text-align: right;
  font-size: 24rpx;
  color: #0f172a;
  word-break: break-all;
}

.loading-state,
.empty-state {
  text-align: center;
  font-size: 26rpx;
  line-height: 1.8;
  color: #64748b;
}

.progress-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 26rpx;
}

.progress-badge,
.question-tag,
.chip,
.question-status-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.progress-badge {
  background: #dbeafe;
  color: #1d4ed8;
}

.question-tag {
  background: #ecfccb;
  color: #3f6212;
}

.question-status-tag-correct {
  background: #dcfce7;
  color: #166534;
}

.question-status-tag-wrong {
  background: #fee2e2;
  color: #b91c1c;
}

.section-title {
  margin: 24rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.stem-card,
.option-card,
.answer-summary {
  border-radius: 22rpx;
  background: #f8fafc;
}

.stem-card {
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #0f172a;
}

.answer-summary {
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.answer-summary-label {
  font-size: 24rpx;
  color: #64748b;
}

.answer-summary-value {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 600;
}

.image-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.content-image,
.option-image,
.grouped-image {
  width: 100%;
  border-radius: 22rpx;
  overflow: hidden;
  background: #f8fafc;
}

.option-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  padding: 22rpx;
  border: 2rpx solid transparent;
}

.option-card-selected {
  border-color: #16a34a;
  background: linear-gradient(180deg, #f0fdf4 0%, #eef6ff 100%);
}

.option-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.option-key {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.option-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #334155;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.chip {
  background: #e2e8f0;
  color: #334155;
}

.chip-selected {
  background: linear-gradient(135deg, #16a34a, #2563eb);
  color: #ffffff;
}

.navigation-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 28rpx;
}

.nav-btn {
  border-radius: 18rpx;
  font-size: 28rpx;
}

.nav-btn-secondary {
  background: #ffffff;
  color: #1e293b;
  border: 1rpx solid rgba(37, 99, 235, 0.18);
}

.nav-btn-primary {
  background: linear-gradient(135deg, #16a34a, #2563eb);
  color: #ffffff;
}

.nav-btn::after {
  border: none;
}

@media (max-width: 480px) {
  .hero-stats,
  .navigation-row {
    grid-template-columns: 1fr;
  }

  .summary-row,
  .answer-summary {
    flex-direction: column;
  }

  .summary-value {
    max-width: none;
    text-align: left;
  }
}
