page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(20, 184, 166, 0.2), transparent 28%),
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.22), transparent 30%),
    linear-gradient(180deg, #f5f8fc 0%, #edf3fa 52%, #eef5f7 100%);
}

.page-shell {
  min-height: 100vh;
  color: #0f172a;
  font-family: "PingFang SC", sans-serif;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(247, 250, 252, 0.82);
  backdrop-filter: blur(20rpx);
}

.custom-nav-inner {
  height: 88rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.custom-nav-caption {
  font-size: 32rpx;
  font-weight: 600;
  color: #0f172a;
}

.custom-nav-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.nav-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.nav-triangle-left {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 20rpx solid #0f172a;
  margin-left: -4rpx;
}

.nav-home-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.nav-home-roof {
  position: absolute;
  top: -2rpx;
  left: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid #0f172a;
  border-left: 4rpx solid #0f172a;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.nav-home-body {
  position: absolute;
  left: 5rpx;
  bottom: 0;
  width: 18rpx;
  height: 16rpx;
  border: 4rpx solid #0f172a;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.page-body {
  position: relative;
  overflow: hidden;
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(24rpx);
  pointer-events: none;
}

.ambient-left {
  top: 28rpx;
  left: -90rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(16, 185, 129, 0.14);
}

.ambient-right {
  top: 120rpx;
  right: -80rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(59, 130, 246, 0.16);
}

.hero-card,
.refresh-card,
.loading-state,
.empty-state,
.history-card {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(249, 251, 255, 0.94) 48%, rgba(243, 249, 255, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: 0 28rpx 72rpx rgba(15, 23, 42, 0.1), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.hero-shine {
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 280rpx;
  height: 180rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0));
  transform: rotate(-14deg);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #475569;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 64rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -1.2rpx;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: #64748b;
}

.refresh-card,
.loading-state,
.empty-state,
.history-card {
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.06);
}

.ghost-btn {
  width: 100%;
  border-radius: 18rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  color: #2563eb;
}

.ghost-btn::after {
  border: none;
}

.loading-state,
.empty-state {
  text-align: center;
  font-size: 26rpx;
  line-height: 1.8;
  color: #64748b;
}

.history-card-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.history-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.history-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.history-score {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #16a34a, #2563eb);
  color: #ffffff;
  font-size: 24rpx;
}

.history-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.history-item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef6ff 100%);
}

.history-item-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.history-item-label,
.history-id {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.history-id {
  margin-top: 20rpx;
  word-break: break-all;
}

@media (max-width: 480px) {
  .history-grid {
    grid-template-columns: 1fr;
  }

  .history-card-top {
    flex-direction: column;
  }
}
