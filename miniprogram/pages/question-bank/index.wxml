<view class="page-container">
  <view class="page-back-row">
    <view class="page-back-actions">
      <view class="page-icon-btn" bindtap="goBack" aria-label="返回">
        <view class="page-triangle-left"></view>
      </view>
      <view class="page-icon-btn" bindtap="goHome" aria-label="回到首页">
        <view class="page-home-icon">
          <view class="page-home-roof"></view>
          <view class="page-home-body"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="hero-card">
    <view class="hero-top">
      <view>
        <view class="title">题库管理</view>
        <view class="top_tip">管理员可在这里维护题目列表、查看详情并进行批量录入，详情弹窗会按需加载并缓存。</view>
      </view>
      <view class="role-badge {{isAdmin ? 'role-badge-admin' : 'role-badge-user'}}">
        {{currentUser.role || '未同步'}}
      </view>
    </view>
    <view class="hero-stats">
      <view class="hero-stat">
        <view class="hero-stat-value">{{totalQuestionCount}}</view>
        <view class="hero-stat-label">题目总数</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{isAdmin ? (listHasMore ? '可继续' : '已到底') : '受限'}}</view>
        <view class="hero-stat-label">列表状态</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{selectedDetailSource === 'cache' ? '缓存' : '实时'}}</view>
        <view class="hero-stat-label">详情来源</view>
      </view>
    </view>
  </view>

  <view class="summary-card">
    <view class="panel-title">当前会话</view>
    <view class="summary-row">
      <view class="summary-label">OpenID</view>
      <view class="summary-value">{{currentUser.openid || '待同步'}}</view>
    </view>
    <view class="summary-row">
      <view class="summary-label">当前角色</view>
      <view class="summary-value">{{currentUser.role || 'user'}}</view>
    </view>
  </view>

  <view class="toolbar">
    <button class="btn-full toolbar-btn toolbar-btn-secondary" bindtap="refreshCurrentUser" loading="{{loadingUser}}">刷新用户</button>
    <button class="btn-full toolbar-btn" wx:if="{{isAdmin}}" bindtap="refreshQuestionSummaries" loading="{{loadingQuestions}}">刷新列表</button>
    <button class="btn-full toolbar-btn toolbar-btn-accent" wx:if="{{isAdmin}}" bindtap="openCreateQuestion">新增题目</button>
  </view>

  <view class="empty-state" wx:if="{{!isAdmin && userLoaded}}">
    当前账号不是管理员，题目总列表已隐藏。管理员身份同步后可查看分页预览与详情。
  </view>

  <view class="empty-state" wx:if="{{isAdmin && initialLoading}}">
    正在加载题目预览列表...
  </view>

  <view class="empty-state" wx:if="{{isAdmin && listLoaded && !questionSummaries.length && !initialLoading}}">
    暂无题目数据，请先由管理员新增题目。
  </view>

  <view class="question-list" wx:if="{{isAdmin && questionSummaries.length}}">
    <view class="list-title-row">
      <view class="list-title">题目列表</view>
      <view class="list-subtitle">支持单题与题组分页预览</view>
    </view>
    <view class="question-card summary-question-card" wx:for="{{questionSummaries}}" wx:key="summaryId" wx:for-item="question">
      <view wx:if="{{question.entityType === 'single'}}">
        <view class="question-header">
          <view class="summary-main">
            <view class="question-id">{{question.questionLabel}}</view>
            <view class="question-meta">
              <text class="tag">单题</text>
              <text class="tag">{{question.preview.optionModeLabel}}</text>
              <text class="tag" wx:if="{{question.preview.hasStemImage}}">有图</text>
              <text class="tag">更新于 {{question.updateTimeText}}</text>
            </view>
          </view>
          <view class="question-actions">
            <button size="mini" bindtap="viewQuestionDetail" data-questionid="{{question.questionId}}" data-version="{{question.version}}">详情</button>
            <button size="mini" type="warn" wx:if="{{isAdmin}}" loading="{{deletingQuestionId === question.questionId}}" bindtap="deleteQuestion" data-questionid="{{question.questionId}}">删除</button>
          </view>
        </view>
        <view class="summary-preview-card">{{question.preview.stemText}}</view>
        <view class="summary-extra">
          <text class="summary-extra-text">选项：{{question.preview.optionKeysText}}</text>
        </view>
      </view>

      <view wx:if="{{question.entityType === 'group'}}">
        <view class="question-header">
          <view class="summary-main">
            <view class="question-id">{{question.groupId}}</view>
            <view class="question-meta">
              <text class="tag tag-strong">题组</text>
              <text class="tag">{{question.childCount}} 个子题</text>
              <text class="tag" wx:if="{{question.sharedStemPreview.hasStemImage}}">公共题干有图</text>
              <text class="tag">更新于 {{question.updateTimeText}}</text>
            </view>
          </view>
          <view class="question-actions">
            <button size="mini" bindtap="toggleGroupExpanded" data-groupid="{{question.groupId}}">
              {{question.isExpanded ? '收起' : '展开'}}
            </button>
            <button size="mini" type="warn" wx:if="{{isAdmin}}" loading="{{deletingQuestionId === question.groupId}}" bindtap="deleteQuestionGroup" data-groupid="{{question.groupId}}">删除题组</button>
          </view>
        </view>
        <view class="summary-preview-card">{{question.sharedStemPreview.stemText}}</view>

        <view class="group-preview-list" wx:if="{{question.isExpanded}}">
          <view class="group-preview-item" wx:for="{{question.childrenPreview}}" wx:key="questionId" wx:for-item="child">
            <view class="group-preview-main">
              <view class="group-preview-title">{{child.questionLabel}}</view>
              <view class="question-meta">
                <text class="tag">{{child.preview.optionModeLabel}}</text>
                <text class="tag" wx:if="{{child.preview.hasStemImage}}">有图</text>
                <text class="tag">选项 {{child.preview.optionKeysText}}</text>
              </view>
              <view class="group-preview-text">{{child.preview.stemText}}</view>
            </view>
            <view class="group-preview-actions">
              <button size="mini" bindtap="viewQuestionDetail" data-questionid="{{child.questionId}}" data-groupid="{{question.groupId}}" data-version="{{question.version}}">详情</button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="list-footer" wx:if="{{isAdmin && questionSummaries.length}}">
    <view class="footer-text" wx:if="{{loadingMore}}">正在加载更多题目...</view>
    <view class="footer-text" wx:if="{{!loadingMore && listHasMore}}">上拉继续加载更多</view>
    <view class="footer-text" wx:if="{{!loadingMore && !listHasMore}}">已经到底了</view>
  </view>

  <view class="modal-mask" wx:if="{{showDetailModal}}">
    <view class="detail-modal">
      <view class="modal-title">题目详情</view>
      <view class="detail-hint-row">
        <text class="detail-hint">数据来源：{{selectedDetailSource === 'cache' ? '本地缓存' : '网络最新'}}</text>
      </view>

      <view wx:if="{{selectedDetailType === 'single'}}">
        <view class="detail-question-id">题号：{{selectedDetail.questionLabel}}</view>
        <view class="detail-question-id">题目 ID：{{selectedDetail.questionId}}</view>
        <view class="section-title">题干</view>
        <view wx:if="{{selectedDetail.stem.imageFileIds.length}}" class="content-image-list">
          <view class="content-image-item" wx:for="{{selectedDetail.stem.imageFileIds}}" wx:key="*this">
            <image class="preview-image clickable-image" mode="widthFix" src="{{item}}" bindtap="previewQuestionImages" data-src="{{item}}" data-questionid="{{selectedDetail.questionId}}"></image>
          </view>
        </view>
        <view wx:if="{{selectedDetail.stem.text}}" class="stem-text-card">{{selectedDetail.stem.text}}</view>
        <view class="section-title">选项</view>
        <view wx:if="{{selectedDetail.optionMode === 'per_option'}}" class="option-list">
          <view class="option-card" wx:for="{{selectedDetail.options.items}}" wx:key="key" wx:for-item="option">
            <view class="option-key">{{option.key}}</view>
            <view wx:if="{{option.sourceType === 'text'}}" class="option-text-card">{{option.text}}</view>
            <image wx:if="{{option.sourceType === 'image' && option.imageFileId}}" class="option-image clickable-image" mode="widthFix" src="{{option.imageFileId}}" bindtap="previewQuestionImages" data-src="{{option.imageFileId}}" data-questionid="{{selectedDetail.questionId}}"></image>
          </view>
        </view>
        <view wx:if="{{selectedDetail.optionMode === 'grouped_asset'}}">
          <image wx:if="{{selectedDetail.options.groupedAsset.imageFileId}}" class="preview-image clickable-image" mode="widthFix" src="{{selectedDetail.options.groupedAsset.imageFileId}}" bindtap="previewQuestionImages" data-src="{{selectedDetail.options.groupedAsset.imageFileId}}" data-questionid="{{selectedDetail.questionId}}"></image>
          <view class="chip-list">
            <view class="chip" wx:for="{{selectedDetail.options.keys}}" wx:key="*this">{{item}}</view>
          </view>
        </view>
        <view class="answer-row" wx:if="{{isAdmin}}">正确答案：{{selectedDetail.correctOptionText}}</view>
      </view>

      <view wx:if="{{selectedDetailType === 'grouped'}}">
        <view class="detail-question-id">题组 ID：{{selectedDetail.groupId}}</view>
        <view class="section-title">公共题干</view>
        <view wx:if="{{selectedDetail.sharedStem.imageFileIds.length}}" class="content-image-list">
          <view class="content-image-item" wx:for="{{selectedDetail.sharedStem.imageFileIds}}" wx:key="*this">
            <image class="preview-image clickable-image" mode="widthFix" src="{{item}}" bindtap="previewQuestionImages" data-src="{{item}}" data-groupid="{{selectedDetail.groupId}}"></image>
          </view>
        </view>
        <view wx:if="{{selectedDetail.sharedStem.text}}" class="stem-text-card">{{selectedDetail.sharedStem.text}}</view>

        <view class="section-title">子题切换</view>
        <scroll-view class="detail-child-tabs" scroll-x>
          <view class="detail-child-tab {{item.isActive ? 'detail-child-tab-active' : ''}}" wx:for="{{detailChildTabs}}" wx:key="questionId" bindtap="switchDetailChild" data-questionid="{{item.questionId}}">
            {{item.label}}
          </view>
        </scroll-view>

        <view wx:if="{{selectedDetailActiveChild}}">
          <view class="detail-question-id detail-question-id-inner">题号：{{selectedDetailActiveChild.questionLabel}}</view>
          <view class="detail-question-id detail-question-id-inner">题目 ID：{{selectedDetailActiveChild.questionId}}</view>
          <view class="section-title">题干</view>
          <view wx:if="{{selectedDetailActiveChild.stem.imageFileIds.length}}" class="content-image-list">
            <view class="content-image-item" wx:for="{{selectedDetailActiveChild.stem.imageFileIds}}" wx:key="*this">
              <image class="preview-image clickable-image" mode="widthFix" src="{{item}}" bindtap="previewQuestionImages" data-src="{{item}}" data-questionid="{{selectedDetailActiveChild.questionId}}" data-groupid="{{selectedDetail.groupId}}"></image>
            </view>
          </view>
          <view wx:if="{{selectedDetailActiveChild.stem.text}}" class="stem-text-card">{{selectedDetailActiveChild.stem.text}}</view>
          <view class="section-title">选项</view>
          <view wx:if="{{selectedDetailActiveChild.optionMode === 'per_option'}}" class="option-list">
            <view class="option-card" wx:for="{{selectedDetailActiveChild.options.items}}" wx:key="key" wx:for-item="option">
              <view class="option-key">{{option.key}}</view>
              <view wx:if="{{option.sourceType === 'text'}}" class="option-text-card">{{option.text}}</view>
              <image wx:if="{{option.sourceType === 'image' && option.imageFileId}}" class="option-image clickable-image" mode="widthFix" src="{{option.imageFileId}}" bindtap="previewQuestionImages" data-src="{{option.imageFileId}}" data-questionid="{{selectedDetailActiveChild.questionId}}" data-groupid="{{selectedDetail.groupId}}"></image>
            </view>
          </view>
          <view wx:if="{{selectedDetailActiveChild.optionMode === 'grouped_asset'}}">
            <image wx:if="{{selectedDetailActiveChild.options.groupedAsset.imageFileId}}" class="preview-image clickable-image" mode="widthFix" src="{{selectedDetailActiveChild.options.groupedAsset.imageFileId}}" bindtap="previewQuestionImages" data-src="{{selectedDetailActiveChild.options.groupedAsset.imageFileId}}" data-questionid="{{selectedDetailActiveChild.questionId}}" data-groupid="{{selectedDetail.groupId}}"></image>
            <view class="chip-list">
              <view class="chip" wx:for="{{selectedDetailActiveChild.options.keys}}" wx:key="*this">{{item}}</view>
            </view>
          </view>
          <view class="answer-row" wx:if="{{isAdmin}}">正确答案：{{selectedDetailActiveChild.correctOptionText}}</view>
        </view>
      </view>

      <view class="btn-full" bindtap="closeDetailModal">关闭</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showEditorModal}}">
    <view class="editor-modal">
      <view class="modal-title">{{editorMode === 'edit' ? '编辑题目' : '新增题目'}}</view>
      <view class="section-title">录入模式</view>
      <view class="segmented">
        <view class="segmented-item {{editorEntryMode === 'single' ? 'segmented-item-active' : ''}}" bindtap="switchEditorEntryMode" data-mode="single">单题</view>
        <view class="segmented-item {{editorEntryMode === 'grouped' ? 'segmented-item-active' : ''}}" bindtap="switchEditorEntryMode" data-mode="grouped">关联题</view>
      </view>

      <view wx:if="{{editorEntryMode === 'single'}}">
        <view class="detail-question-id" wx:if="{{editorMode === 'edit'}}">题目 ID：{{editorForm.single.questionId}}</view>
        <view class="section-title">题号昵称</view>
        <input class="text-input" value="{{editorForm.single.questionLabel}}" bindinput="onQuestionLabelInput" placeholder="请输入题号昵称" maxlength="-1" />

        <view class="section-title">题干</view>
        <textarea class="text-area" value="{{editorForm.single.stem.text}}" bindinput="onStemTextInput" placeholder="请输入题干文本，可与图片同时存在" auto-height maxlength="-1"></textarea>
        <view class="btn-full secondary-btn" bindtap="uploadStemImages">上传题干图片</view>
        <view class="content-image-list">
          <view class="content-image-item" wx:for="{{editorForm.single.stem.imageFileIds}}" wx:key="*this" wx:for-index="imgIndex">
            <image class="preview-image clickable-image" mode="widthFix" src="{{item}}" bindtap="previewSingleImage" data-src="{{item}}"></image>
            <view class="mini-actions"><button size="mini" type="warn" bindtap="removeStemImage" data-index="{{imgIndex}}">删除</button></view>
          </view>
        </view>

        <view class="section-title">选项模式</view>
        <view class="segmented">
          <view class="segmented-item {{editorForm.single.optionMode === 'per_option' ? 'segmented-item-active' : ''}}" bindtap="switchOptionMode" data-mode="per_option">独立选项</view>
          <view class="segmented-item {{editorForm.single.optionMode === 'grouped_asset' ? 'segmented-item-active' : ''}}" bindtap="switchOptionMode" data-mode="grouped_asset">大图模式</view>
        </view>

        <view wx:if="{{editorForm.single.optionMode === 'per_option'}}">
          <view class="option-editor" wx:for="{{editorForm.single.options.items}}" wx:key="key" wx:for-item="option" wx:for-index="index">
            <view class="option-editor-top">
              <input class="option-key-input" value="{{option.key}}" data-index="{{index}}" bindinput="onOptionKeyInput" maxlength="100" />
              <view class="segmented segmented-small">
                <view class="segmented-item segmented-item-small {{option.sourceType === 'text' ? 'segmented-item-active' : ''}}" bindtap="switchOptionSourceType" data-index="{{index}}" data-type="text">文本</view>
                <view class="segmented-item segmented-item-small {{option.sourceType === 'image' ? 'segmented-item-active' : ''}}" bindtap="switchOptionSourceType" data-index="{{index}}" data-type="image">图片</view>
              </view>
              <button size="mini" type="warn" bindtap="removeOption" data-index="{{index}}">删除</button>
            </view>
            <textarea wx:if="{{option.sourceType === 'text'}}" class="text-area text-area-small" value="{{option.text}}" bindinput="onOptionTextInput" data-index="{{index}}" placeholder="请输入选项 {{option.key}} 文本" auto-height maxlength="-1"></textarea>
            <view wx:if="{{option.sourceType === 'image'}}">
              <view class="btn-full secondary-btn" bindtap="uploadOptionImage" data-index="{{index}}">上传选项图片</view>
              <image wx:if="{{option.imageFileId}}" class="option-image clickable-image" mode="widthFix" src="{{option.imageFileId}}" bindtap="previewSingleImage" data-src="{{option.imageFileId}}"></image>
              <view class="mini-actions"><button size="mini" type="warn" bindtap="removeOptionImage" data-index="{{index}}">删除图片</button></view>
            </view>
          </view>
          <view class="btn-full" bindtap="addOption">新增选项</view>
        </view>

        <view wx:if="{{editorForm.single.optionMode === 'grouped_asset'}}">
          <view class="grouped-asset-box">
            <view class="grouped-asset-label">覆盖大图</view>
            <view class="btn-full secondary-btn" bindtap="uploadGroupedAssetImage">上传覆盖大图</view>
            <image wx:if="{{editorForm.single.options.groupedAsset.imageFileId}}" class="preview-image clickable-image" mode="widthFix" src="{{editorForm.single.options.groupedAsset.imageFileId}}" bindtap="previewSingleImage" data-src="{{editorForm.single.options.groupedAsset.imageFileId}}"></image>
            <view class="mini-actions"><button size="mini" type="warn" bindtap="removeGroupedAssetImage">删除图片</button></view>
          </view>
          <view class="grouped-key-head">
            <view class="section-title">选项标识</view>
            <view class="grouped-key-hint">请保持 Key 唯一，例如 A/B/C/D。</view>
          </view>
          <view class="grouped-key-list">
            <view class="grouped-key-item" wx:for="{{editorForm.single.options.keys}}" wx:key="*this" wx:for-item="key" wx:for-index="keyIndex">
              <input class="option-key-input" value="{{key}}" data-index="{{keyIndex}}" bindinput="onOptionKeyInput" maxlength="100" />
              <button size="mini" type="warn" bindtap="removeOption" data-index="{{keyIndex}}">删除</button>
            </view>
          </view>
          <view class="btn-full" bindtap="addOption">新增选项标识</view>
        </view>

        <view class="section-title">正确答案</view>
        <checkbox-group bindchange="onCorrectOptionChange">
          <label class="checkbox-item" wx:for="{{editorForm.single.answerChoices}}" wx:key="key" wx:for-item="choice">
            <checkbox value="{{choice.key}}" checked="{{choice.checked}}" />
            <text>{{choice.key}}</text>
          </label>
        </checkbox-group>
      </view>

      <view wx:if="{{editorEntryMode === 'grouped'}}">
        <view class="detail-question-id" wx:if="{{editorMode === 'edit'}}">题组 ID：{{editorForm.grouped.groupId}}</view>
        <view class="section-title">公共题干</view>
        <textarea class="text-area" value="{{editorForm.grouped.sharedStem.text}}" bindinput="onStemTextInput" data-scope="group-shared" placeholder="请输入公共题干文本，可与图片同时存在" auto-height maxlength="-1"></textarea>
        <view class="btn-full secondary-btn" bindtap="uploadStemImages" data-scope="group-shared">上传公共题干图片</view>
        <view class="content-image-list">
          <view class="content-image-item" wx:for="{{editorForm.grouped.sharedStem.imageFileIds}}" wx:key="*this" wx:for-index="imgIndex">
            <image class="preview-image clickable-image" mode="widthFix" src="{{item}}" bindtap="previewSingleImage" data-src="{{item}}"></image>
            <view class="mini-actions"><button size="mini" type="warn" bindtap="removeStemImage" data-scope="group-shared" data-index="{{imgIndex}}">删除</button></view>
          </view>
        </view>

        <view class="section-title">子题列表</view>
        <view class="question-card question-card-inner" wx:for="{{editorForm.grouped.children}}" wx:key="questionId" wx:for-item="child" wx:for-index="childIndex">
          <view class="question-header">
            <view class="question-id">{{child.questionLabel || ('第 ' + (childIndex + 1) + ' 题')}}</view>
            <view class="question-actions">
              <button size="mini" bindtap="moveChildQuestionUp" data-child-index="{{childIndex}}">上移</button>
              <button size="mini" bindtap="moveChildQuestionDown" data-child-index="{{childIndex}}">下移</button>
              <button size="mini" type="warn" bindtap="removeChildQuestion" data-child-index="{{childIndex}}">删除子题</button>
            </view>
          </view>
          <view class="detail-question-id" wx:if="{{editorMode === 'edit' && child.questionId}}">题目 ID：{{child.questionId}}</view>
          <view class="section-title">题号昵称</view>
          <input class="text-input" value="{{child.questionLabel}}" bindinput="onQuestionLabelInput" data-scope="group-child" data-child-index="{{childIndex}}" placeholder="请输入子题题号昵称" maxlength="-1" />

          <view class="section-title">题干</view>
          <textarea class="text-area" value="{{child.stem.text}}" bindinput="onStemTextInput" data-scope="group-child" data-child-index="{{childIndex}}" placeholder="请输入子题题干文本，可与图片同时存在" auto-height maxlength="-1"></textarea>
          <view class="btn-full secondary-btn" bindtap="uploadStemImages" data-scope="group-child" data-child-index="{{childIndex}}">上传子题图片</view>
          <view class="content-image-list">
            <view class="content-image-item" wx:for="{{child.stem.imageFileIds}}" wx:key="*this" wx:for-index="imgIndex">
              <image class="preview-image clickable-image" mode="widthFix" src="{{item}}" bindtap="previewSingleImage" data-src="{{item}}"></image>
              <view class="mini-actions"><button size="mini" type="warn" bindtap="removeStemImage" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{imgIndex}}">删除</button></view>
            </view>
          </view>

          <view class="section-title">选项模式</view>
          <view class="segmented">
            <view class="segmented-item {{child.optionMode === 'per_option' ? 'segmented-item-active' : ''}}" bindtap="switchOptionMode" data-scope="group-child" data-child-index="{{childIndex}}" data-mode="per_option">独立选项</view>
            <view class="segmented-item {{child.optionMode === 'grouped_asset' ? 'segmented-item-active' : ''}}" bindtap="switchOptionMode" data-scope="group-child" data-child-index="{{childIndex}}" data-mode="grouped_asset">大图模式</view>
          </view>

          <view wx:if="{{child.optionMode === 'per_option'}}">
            <view class="option-editor" wx:for="{{child.options.items}}" wx:key="key" wx:for-item="option" wx:for-index="optIndex">
              <view class="option-editor-top">
                <input class="option-key-input" value="{{option.key}}" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}" bindinput="onOptionKeyInput" maxlength="100" />
                <view class="segmented segmented-small">
                  <view class="segmented-item segmented-item-small {{option.sourceType === 'text' ? 'segmented-item-active' : ''}}" bindtap="switchOptionSourceType" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}" data-type="text">文本</view>
                  <view class="segmented-item segmented-item-small {{option.sourceType === 'image' ? 'segmented-item-active' : ''}}" bindtap="switchOptionSourceType" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}" data-type="image">图片</view>
                </view>
                <button size="mini" type="warn" bindtap="removeOption" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}">删除</button>
              </view>
              <textarea wx:if="{{option.sourceType === 'text'}}" class="text-area text-area-small" value="{{option.text}}" bindinput="onOptionTextInput" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}" placeholder="请输入选项 {{option.key}} 文本" auto-height maxlength="-1"></textarea>
              <view wx:if="{{option.sourceType === 'image'}}">
                <view class="btn-full secondary-btn" bindtap="uploadOptionImage" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}">上传选项图片</view>
                <image wx:if="{{option.imageFileId}}" class="option-image clickable-image" mode="widthFix" src="{{option.imageFileId}}" bindtap="previewSingleImage" data-src="{{option.imageFileId}}"></image>
                <view class="mini-actions"><button size="mini" type="warn" bindtap="removeOptionImage" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{optIndex}}">删除图片</button></view>
              </view>
            </view>
            <view class="btn-full" bindtap="addOption" data-scope="group-child" data-child-index="{{childIndex}}">新增选项</view>
          </view>

          <view wx:if="{{child.optionMode === 'grouped_asset'}}">
            <view class="grouped-asset-box">
              <view class="grouped-asset-label">覆盖大图</view>
              <view class="btn-full secondary-btn" bindtap="uploadGroupedAssetImage" data-scope="group-child" data-child-index="{{childIndex}}">上传覆盖大图</view>
              <image wx:if="{{child.options.groupedAsset.imageFileId}}" class="preview-image clickable-image" mode="widthFix" src="{{child.options.groupedAsset.imageFileId}}" bindtap="previewSingleImage" data-src="{{child.options.groupedAsset.imageFileId}}"></image>
              <view class="mini-actions"><button size="mini" type="warn" bindtap="removeGroupedAssetImage" data-scope="group-child" data-child-index="{{childIndex}}">删除图片</button></view>
            </view>
            <view class="grouped-key-head">
              <view class="section-title">选项标识</view>
              <view class="grouped-key-hint">请保持 Key 唯一，例如 A/B/C/D。</view>
            </view>
            <view class="grouped-key-list">
              <view class="grouped-key-item" wx:for="{{child.options.keys}}" wx:key="*this" wx:for-item="key" wx:for-index="keyIndex">
                <input class="option-key-input" value="{{key}}" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{keyIndex}}" bindinput="onOptionKeyInput" maxlength="100" />
                <button size="mini" type="warn" bindtap="removeOption" data-scope="group-child" data-child-index="{{childIndex}}" data-index="{{keyIndex}}">删除</button>
              </view>
            </view>
            <view class="btn-full" bindtap="addOption" data-scope="group-child" data-child-index="{{childIndex}}">新增选项标识</view>
          </view>

          <view class="section-title">正确答案</view>
          <checkbox-group bindchange="onCorrectOptionChange" data-scope="group-child" data-child-index="{{childIndex}}">
            <label class="checkbox-item" wx:for="{{child.answerChoices}}" wx:key="key" wx:for-item="choice">
              <checkbox value="{{choice.key}}" checked="{{choice.checked}}" />
              <text>{{choice.key}}</text>
            </label>
          </checkbox-group>
        </view>

        <view class="btn-full" bindtap="addChildQuestion">新增子题</view>
      </view>

      <view class="modal-actions">
        <view class="button_clear editor-action" bindtap="closeEditor">取消</view>
        <view class="btn-full editor-action" bindtap="saveQuestion" loading="{{savingQuestion}}">保存</view>
      </view>
    </view>
  </view>

  <cloud-tip-modal showTipProps="{{showTip}}" title="{{title}}" content="{{content}}" bindclose="hideCloudTip"></cloud-tip-modal>
</view>
