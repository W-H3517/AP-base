page {
  background-color: #fff;
  padding-bottom: 50px;
  font-family: PingFang SC;
}

.page-container {
  padding: 20rpx 40rpx;
}

.top_tip {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 30rpx;
}

.title {
  margin-top: 16px;
  margin-bottom: 8px;
  font-size: 36rpx;
  font-weight: 500;
  color: #000;
}

.summary-card,
.question-card,
.detail-modal,
.editor-modal {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.summary-card {
  background-color: #f7f9fc;
  padding: 24rpx;
  margin: 24rpx 0;
}

.summary-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-label {
  width: 140rpx;
  color: rgba(0, 0, 0, 0.55);
  font-size: 26rpx;
}

.summary-value {
  flex: 1;
  color: rgba(0, 0, 0, 0.85);
  font-size: 26rpx;
  word-break: break-all;
}

.toolbar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.toolbar-btn {
  margin-bottom: 0;
}

.empty-state {
  padding: 80rpx 24rpx;
  color: rgba(0, 0, 0, 0.5);
  text-align: center;
  background-color: #f7f9fc;
  border-radius: 16rpx;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.question-card {
  padding: 24rpx;
}

.question-card-inner {
  margin-top: 16rpx;
  box-shadow: none;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.question-id,
.detail-question-id {
  color: rgba(0, 0, 0, 0.85);
  font-size: 28rpx;
  font-weight: 600;
  word-break: break-all;
}

.question-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.6);
  background: rgba(0, 0, 0, 0.05);
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.tag-strong {
  color: #1a8f3d;
  background: rgba(26, 173, 25, 0.12);
}

.question-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.section-title {
  margin: 20rpx 0 12rpx;
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.8);
  font-weight: 500;
}

.stem-text-card,
.option-text-card {
  background-color: #f8fafc;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: rgba(0, 0, 0, 0.84);
  font-size: 28rpx;
  line-height: 44rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.content-image-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.content-image-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-image,
.option-image {
  width: 100%;
  border-radius: 12rpx;
  background-color: #f6f6f6;
}

.clickable-image:active {
  opacity: 0.82;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  background-color: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.option-key {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.7);
  font-weight: 500;
}

.answer-row {
  margin-top: 16rpx;
  color: #1a8f3d;
  font-size: 26rpx;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-modal,
.editor-modal {
  width: 88%;
  max-height: 85vh;
  overflow: scroll;
  padding: 24px;
}

.modal-title {
  font-size: 18px;
  margin-bottom: 16px;
}

.segmented {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.segmented-small {
  gap: 8rpx;
  margin-bottom: 0;
}

.segmented-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 16rpx;
  border-radius: 999rpx;
  background-color: rgba(0, 0, 0, 0.05);
  color: rgba(0, 0, 0, 0.72);
  font-size: 26rpx;
}

.segmented-item-small {
  padding: 10rpx 14rpx;
  font-size: 22rpx;
}

.segmented-item-active {
  background-color: rgba(26, 173, 25, 0.14);
  color: #1aad19;
  font-weight: 600;
}

.text-area {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.12);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  line-height: 42rpx;
  background-color: #fff;
}

.text-area-small {
  min-height: 120rpx;
  margin-bottom: 12rpx;
}

.secondary-btn {
  background-color: rgba(0, 0, 0, 0.04);
  color: #1aad19;
}

.option-editor {
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.option-editor-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.option-key-input {
  width: 120rpx;
  height: 64rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.15);
  border-radius: 8rpx;
  padding: 0 16rpx;
}

.grouped-asset-box {
  border: 1rpx dashed rgba(0, 0, 0, 0.14);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.grouped-asset-label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.72);
  margin-bottom: 12rpx;
}

.grouped-key-head {
  margin-top: 4rpx;
}

.grouped-key-hint {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 10rpx;
}

.grouped-key-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.grouped-key-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background-color: rgba(26, 173, 25, 0.12);
  color: #1a8f3d;
  font-size: 24rpx;
  font-weight: 500;
}

.mini-actions {
  margin-top: 8rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.editor-action {
  flex: 1;
  width: auto;
  margin: 0;
}
