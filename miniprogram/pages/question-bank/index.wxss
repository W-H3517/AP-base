page {
  background:
    radial-gradient(circle at top right, rgba(251, 191, 36, 0.16), transparent 24%),
    linear-gradient(180deg, #f6f8fc 0%, #edf4f0 52%, #e8f0ea 100%);
  padding-bottom: 72rpx;
  font-family: PingFang SC;
}

.page-container {
  padding: 24rpx 28rpx 48rpx;
}

.page-back-row {
  margin-bottom: 18rpx;
}

.page-back-actions {
  display: flex;
  gap: 14rpx;
}

.page-icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  width: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 10rpx 24rpx rgba(20, 33, 61, 0.08);
}

.page-triangle-left {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 20rpx solid #1d3557;
  margin-left: -4rpx;
}

.page-home-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.page-home-roof {
  position: absolute;
  top: -2rpx;
  left: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid #1d3557;
  border-left: 4rpx solid #1d3557;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.page-home-body {
  position: absolute;
  left: 5rpx;
  bottom: 0;
  width: 18rpx;
  height: 16rpx;
  border: 4rpx solid #1d3557;
  border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  box-sizing: border-box;
}

.hero-card {
  margin-top: 8rpx;
  padding: 32rpx 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #14213d 0%, #1d3557 56%, #28516f 100%);
  box-shadow: 0 22rpx 52rpx rgba(20, 33, 61, 0.18);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20rpx;
}

.title {
  margin-top: 0;
  font-size: 46rpx;
  font-weight: 700;
  color: #ffffff;
}

.top_tip {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  color: rgba(255, 255, 255, 0.72);
}

.role-badge {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.role-badge-admin {
  background: rgba(245, 158, 11, 0.18);
  color: #fcd34d;
  border: 1rpx solid rgba(252, 211, 77, 0.28);
}

.role-badge-user {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-stat {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.09);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.hero-stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.66);
}

.summary-card,
.question-card,
.detail-modal,
.editor-modal {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(20, 33, 61, 0.08);
}

.summary-card {
  margin: 26rpx 0 0;
  padding: 26rpx 24rpx;
  border: 1rpx solid rgba(20, 33, 61, 0.06);
}

.panel-title {
  margin-bottom: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #14213d;
}

.summary-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-label {
  width: 140rpx;
  font-size: 25rpx;
  color: rgba(20, 33, 61, 0.55);
}

.summary-value {
  flex: 1;
  font-size: 25rpx;
  color: rgba(20, 33, 61, 0.88);
  word-break: break-all;
}

.toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 24rpx 0;
}

.toolbar-btn {
  flex: 1;
  min-width: 200rpx;
  margin-bottom: 0;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  font-size: 27rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(34, 139, 85, 0.16);
}

.toolbar-btn-secondary {
  background: #ffffff;
  color: #1d3557;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.08);
}

.toolbar-btn-accent {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
  box-shadow: 0 14rpx 30rpx rgba(249, 115, 22, 0.26);
}

.empty-state {
  padding: 80rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  color: rgba(20, 33, 61, 0.58);
  text-align: center;
  line-height: 40rpx;
  border: 1rpx solid rgba(20, 33, 61, 0.05);
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.list-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #14213d;
}

.list-subtitle {
  font-size: 22rpx;
  color: rgba(20, 33, 61, 0.48);
}

.question-card {
  padding: 24rpx;
  border: 1rpx solid rgba(20, 33, 61, 0.05);
}

.summary-question-card {
  border: 1rpx solid rgba(20, 33, 61, 0.08);
}

.question-card-inner {
  margin-top: 16rpx;
  border: 1rpx solid rgba(20, 33, 61, 0.08);
  box-shadow: none;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.summary-main {
  flex: 1;
}

.question-id,
.detail-question-id {
  color: #14213d;
  font-size: 28rpx;
  font-weight: 700;
  word-break: break-all;
}

.detail-question-id-inner {
  margin-top: 10rpx;
}

.question-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(29, 53, 87, 0.07);
  color: rgba(20, 33, 61, 0.7);
  font-size: 22rpx;
}

.tag-strong {
  background: rgba(34, 139, 85, 0.16);
  color: #1f7a4b;
}

.question-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-end;
}

.summary-preview-card,
.stem-text-card,
.option-text-card,
.group-preview-text {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f9fbff 0%, #f3f7fb 100%);
  color: rgba(20, 33, 61, 0.86);
  font-size: 27rpx;
  line-height: 42rpx;
  white-space: pre-wrap;
  word-break: break-all;
  border: 1rpx solid rgba(20, 33, 61, 0.05);
}

.summary-extra {
  margin-top: 14rpx;
}

.summary-extra-text {
  font-size: 24rpx;
  color: rgba(20, 33, 61, 0.62);
}

.group-preview-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(20, 33, 61, 0.04), rgba(34, 139, 85, 0.04));
}

.group-preview-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(20, 33, 61, 0.05);
}

.group-preview-main {
  flex: 1;
}

.group-preview-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #14213d;
}

.group-preview-actions {
  display: flex;
  align-items: center;
}

.list-footer {
  padding: 24rpx 0 8rpx;
}

.footer-text {
  text-align: center;
  font-size: 24rpx;
  color: rgba(20, 33, 61, 0.5);
}

.section-title {
  margin: 20rpx 0 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(20, 33, 61, 0.86);
}

.content-image-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.content-image-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-image,
.option-image {
  width: 100%;
  border-radius: 16rpx;
  background: #eef2f7;
}

.clickable-image:active {
  opacity: 0.82;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option-card {
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(20, 33, 61, 0.04);
}

.option-key {
  margin-bottom: 12rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: rgba(20, 33, 61, 0.72);
}

.answer-row {
  margin-top: 16rpx;
  color: #1f7a4b;
  font-size: 26rpx;
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(16, 24, 40, 0.34);
}

.detail-modal,
.editor-modal {
  width: 92%;
  max-height: 88vh;
  overflow: scroll;
  padding: 28rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #14213d;
  margin-bottom: 18rpx;
}

.detail-hint-row {
  margin-bottom: 14rpx;
}

.detail-hint {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 98, 254, 0.1);
  color: #0f62fe;
  font-size: 22rpx;
}

.detail-child-tabs {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.detail-child-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(20, 33, 61, 0.06);
  color: rgba(20, 33, 61, 0.68);
  font-size: 24rpx;
}

.detail-child-tab-active {
  background: rgba(34, 139, 85, 0.14);
  color: #1f7a4b;
  font-weight: 700;
}

.segmented {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.segmented-small {
  gap: 8rpx;
  margin-bottom: 0;
}

.segmented-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(20, 33, 61, 0.05);
  color: rgba(20, 33, 61, 0.72);
  font-size: 26rpx;
}

.segmented-item-small {
  padding: 10rpx 14rpx;
  font-size: 22rpx;
}

.segmented-item-active {
  background: rgba(34, 139, 85, 0.14);
  color: #1f7a4b;
  font-weight: 700;
}

.text-area {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(20, 33, 61, 0.1);
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  line-height: 42rpx;
  background: #fcfdff;
}

.text-input {
  width: 100%;
  height: 84rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(20, 33, 61, 0.1);
  border-radius: 18rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fcfdff;
}

.text-area-small {
  min-height: 120rpx;
  margin-bottom: 12rpx;
}

.secondary-btn {
  background: rgba(20, 33, 61, 0.05);
  color: #1f7a4b;
  box-shadow: none;
}

.option-editor {
  border: 1rpx solid rgba(20, 33, 61, 0.08);
  border-radius: 20rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  background: rgba(248, 250, 252, 0.92);
}

.option-editor-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.option-key-input {
  width: 120rpx;
  height: 64rpx;
  border: 1rpx solid rgba(20, 33, 61, 0.15);
  border-radius: 14rpx;
  padding: 0 16rpx;
  background: #fff;
}

.grouped-asset-box {
  border: 1rpx dashed rgba(20, 33, 61, 0.14);
  border-radius: 20rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  background: rgba(248, 250, 252, 0.88);
}

.grouped-asset-label {
  font-size: 26rpx;
  color: rgba(20, 33, 61, 0.72);
  margin-bottom: 12rpx;
}

.grouped-key-head {
  margin-top: 4rpx;
}

.grouped-key-hint {
  font-size: 22rpx;
  color: rgba(20, 33, 61, 0.5);
  margin-bottom: 10rpx;
}

.grouped-key-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.grouped-key-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(34, 139, 85, 0.12);
  color: #1f7a4b;
  font-size: 24rpx;
  font-weight: 600;
}

.mini-actions {
  margin-top: 8rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(20, 33, 61, 0.04);
  border: 1rpx solid rgba(20, 33, 61, 0.05);
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.editor-action {
  flex: 1;
  width: auto;
  margin: 0;
}

.btn-full {
  width: 100%;
  margin: 0;
  min-height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  color: #fff;
  background: linear-gradient(135deg, #1f7a4b 0%, #2f9e63 100%);
  border-radius: 18rpx;
}

.button_clear {
  width: 100%;
  min-height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  color: #1d3557;
  background: rgba(20, 33, 61, 0.06);
  border-radius: 18rpx;
}

@media (max-width: 520px) {
  .hero-top,
  .list-title-row,
  .question-header {
    flex-direction: column;
  }

  .question-actions {
    width: 100%;
    justify-content: flex-start;
  }
}
