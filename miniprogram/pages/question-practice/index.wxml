<view class="page-container">
  <view class="hero-card">
    <view class="hero-top">
      <view>
        <view class="hero-title">在线答题</view>
        <view class="hero-subtitle">一次一题，切题前后自动预加载，保持流畅作答体验。</view>
      </view>
      <view class="role-pill">{{currentUser.role || '未同步'}}</view>
    </view>
    <view class="hero-stats">
      <view class="hero-stat">
        <view class="hero-stat-value">{{paperMeta.totalCount}}</view>
        <view class="hero-stat-label">试卷题数</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{loadedQuestionIds.length}}</view>
        <view class="hero-stat-label">已缓存题目</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{currentQuestion ? currentSelectedOptionKeys.length : 0}}</view>
        <view class="hero-stat-label">当前已选</view>
      </view>
    </view>
  </view>

  <view class="session-card">
    <view class="session-title">当前会话</view>
    <view class="session-row">
      <view class="session-label">OpenID</view>
      <view class="session-value">{{currentUser.openid || '待同步'}}</view>
    </view>
    <view class="session-row">
      <view class="session-label">预加载策略</view>
      <view class="session-value">当前题 + 前后各一道题</view>
    </view>
  </view>

  <view class="toolbar">
    <button class="toolbar-btn toolbar-btn-secondary" bindtap="refreshCurrentUser" loading="{{loadingUser}}">刷新用户</button>
    <button class="toolbar-btn" bindtap="refreshPaper" loading="{{loadingPaper}}">刷新试卷</button>
  </view>

  <view class="loading-state" wx:if="{{loadingPaper}}">
    正在准备试卷，请稍候...
  </view>

  <view class="empty-state" wx:if="{{!loadingPaper && !paperQuestionRefs.length}}">
    当前还没有可作答题目，请先由管理员录入题目。
  </view>

  <view class="result-card" wx:if="{{showResultCard && submissionSummary}}">
    <view class="result-title">交卷完成</view>
    <view class="result-grid">
      <view class="result-item">
        <view class="result-value">{{submissionSummary.totalCount}}</view>
        <view class="result-label">总题数</view>
      </view>
      <view class="result-item">
        <view class="result-value">{{submissionSummary.answeredCount}}</view>
        <view class="result-label">已作答</view>
      </view>
      <view class="result-item">
        <view class="result-value">{{submissionSummary.correctCount}}</view>
        <view class="result-label">答对</view>
      </view>
      <view class="result-item">
        <view class="result-value">{{submissionSummary.score}}</view>
        <view class="result-label">得分</view>
      </view>
    </view>
    <view class="result-meta">提交编号：{{submissionSummary.submissionId}}</view>
  </view>

  <view class="question-card" wx:if="{{currentQuestion}}">
    <view class="progress-row">
      <view class="progress-badge">{{currentQuestionIndex + 1}} / {{paperQuestionRefs.length}}</view>
      <view class="question-tag" wx:if="{{currentQuestion.entryMode === 'grouped'}}">题组第 {{currentQuestion.groupOrder}} 题</view>
      <view class="question-tag" wx:if="{{currentQuestion.optionMode === 'grouped_asset'}}">大图选项</view>
      <view class="question-tag" wx:if="{{currentQuestion.optionMode === 'per_option'}}">独立选项</view>
    </view>

    <view class="section-title" wx:if="{{currentQuestion.sharedStemVisible}}">公共题干</view>
    <view class="stem-card" wx:if="{{currentQuestion.sharedStemVisible && currentQuestion.sharedStem.sourceType === 'text'}}">
      {{currentQuestion.sharedStem.text}}
    </view>
    <view class="image-list" wx:if="{{currentQuestion.sharedStemVisible && currentQuestion.sharedStem.sourceType === 'image'}}">
      <image
        wx:for="{{currentQuestion.sharedStem.imageFileIds}}"
        wx:key="*this"
        class="content-image"
        mode="widthFix"
        src="{{item}}"
        bindtap="previewImage"
        data-src="{{item}}"
      ></image>
    </view>

    <view class="section-title">题目</view>
    <view class="stem-card" wx:if="{{currentQuestion.stem.sourceType === 'text'}}">
      {{currentQuestion.stem.text}}
    </view>
    <view class="image-list" wx:if="{{currentQuestion.stem.sourceType === 'image'}}">
      <image
        wx:for="{{currentQuestion.stem.imageFileIds}}"
        wx:key="*this"
        class="content-image"
        mode="widthFix"
        src="{{item}}"
        bindtap="previewImage"
        data-src="{{item}}"
      ></image>
    </view>

    <view class="section-title">作答区</view>
    <view class="answer-hint">支持多选；当前题切换时会保留你的作答。</view>

    <view wx:if="{{currentQuestion.optionMode === 'per_option'}}" class="option-list">
      <view
        class="option-card {{item.selected ? 'option-card-selected' : ''}}"
        wx:for="{{currentQuestion.options.items}}"
        wx:key="key"
        wx:for-item="item"
        bindtap="toggleOptionSelection"
        data-key="{{item.key}}"
      >
        <view class="option-top">
          <view class="option-key">{{item.key}}</view>
          <view class="option-state">{{item.selected ? '已选' : '未选'}}</view>
        </view>
        <view wx:if="{{item.sourceType === 'text'}}" class="option-text">{{item.text}}</view>
        <image
          wx:if="{{item.sourceType === 'image' && item.imageFileId}}"
          class="option-image"
          mode="widthFix"
          src="{{item.imageFileId}}"
          catchtap="previewImage"
          data-src="{{item.imageFileId}}"
        ></image>
      </view>
    </view>

    <view wx:if="{{currentQuestion.optionMode === 'grouped_asset'}}">
      <image
        wx:if="{{currentQuestion.options.groupedAsset.imageFileId}}"
        class="grouped-image"
        mode="widthFix"
        src="{{currentQuestion.options.groupedAsset.imageFileId}}"
        bindtap="previewImage"
        data-src="{{currentQuestion.options.groupedAsset.imageFileId}}"
      ></image>
      <view class="chip-list">
        <view
          class="chip {{item.selected ? 'chip-selected' : ''}}"
          wx:for="{{currentQuestion.optionKeysForDisplay}}"
          wx:key="key"
          bindtap="toggleOptionSelection"
          data-key="{{item.key}}"
        >
          {{item.key}}
        </view>
      </view>
    </view>

    <view class="navigation-row">
      <button class="nav-btn nav-btn-secondary" bindtap="goToPreviousQuestion" disabled="{{!hasPrevious}}">上一题</button>
      <button class="nav-btn nav-btn-primary" bindtap="goToNextQuestion" disabled="{{!hasNext}}">下一题</button>
    </view>

    <button class="submit-btn" bindtap="submitPaper" loading="{{submitting}}">交卷</button>
  </view>

  <cloud-tip-modal
    showTipProps="{{showTip}}"
    title="{{title}}"
    content="{{content}}"
    bindclose="hideCloudTip"
  ></cloud-tip-modal>
</view>
